# Contextual Substitutions for Combine Markers
feature calt {
    # Substitute first combine_marker with left bracket
    sub glyph_13382' @ALL_SYMBOLS glyph_13382 by bracketleft;
    sub glyph_13382' @ALL_SYMBOLS @ALL_SYMBOLS glyph_13382 by bracketleft;
    sub glyph_13382' @ALL_SYMBOLS @ALL_SYMBOLS @ALL_SYMBOLS glyph_13382 by bracketleft;
    sub glyph_13382' @ALL_SYMBOLS @ALL_SYMBOLS @ALL_SYMBOLS @ALL_SYMBOLS glyph_13382 by bracketleft;
    sub bracketleft @ALL_SYMBOLS glyph_13382' by bracketright;
    sub bracketleft @ALL_SYMBOLS @ALL_SYMBOLS glyph_13382' by bracketright;
    sub bracketleft @ALL_SYMBOLS @ALL_SYMBOLS @ALL_SYMBOLS glyph_13382' by bracketright;
    sub bracketleft @ALL_SYMBOLS @ALL_SYMBOLS @ALL_SYMBOLS @ALL_SYMBOLS glyph_13382' by bracketright;
} calt;

# GSUB Mirroring for RTL Layouts
feature rtla {
    sub glyph_13902 by glyph_18224; # east -> west
    sub glyph_18224 by glyph_13902; # west -> east
    sub glyph_26211 by glyph_26212; # northeast -> northwest
    sub glyph_26212 by glyph_26211; # northwest -> northeast
    sub glyph_26245 by glyph_26246; # southeast -> southwest
    sub glyph_26246 by glyph_26245; # southwest -> southeast
    sub glyph_15187 by glyph_16673; # left -> right
    sub glyph_16673 by glyph_15187; # right -> left
    sub glyph_25577 by glyph_25604; # left_turn -> right_turn
    sub glyph_25604 by glyph_25577; # right_turn -> left_turn
} rtla;